# Copy this file to ~/.bamboo-rooster/.env on the host and fill in your values.
# chmod 600 it. The container reads it via a bind mount.
#
# The API key itself does NOT live here. Put it in
# ~/.bamboo-rooster/secrets/api-key (single line, chmod 600).

# --- BambooHR -----------------------------------------------------------------
BAMBOOHR_SUBDOMAIN="your-company-subdomain"
# Optional: pin a specific employee ID. Empty = auto-resolve via /employees/0/
# on first run and cache in state.json.
BAMBOOHR_EMPLOYEE_ID=""

# --- Rooster ------------------------------------------------------------------
# TZ is honoured by busybox crond, date, and sleep — Spain naturally swings
# UTC+1 (winter) / UTC+2 (summer) and tzdata handles DST automatically.
TZ="Europe/Madrid"

# Rate-limit duplicate auth_failure log lines to one per N hours.
# This is NOT a user-facing alert cooldown — there is no alert channel in v1.
ROOSTER_AUTH_FAIL_LOG_COOLDOWN_HOURS="6"

# Cache the whos_out result for N seconds within a single workday so the four
# phases don't each hit the API. Short enough to pick up mid-day-entered sick
# leave between phases.
ROOSTER_WHOS_OUT_CACHE_TTL_SECONDS="1800"

# Set DRY_RUN=1 to skip the actual clock_in/out HTTP call. Gates and logging
# still run, so this is the safest way to verify a fresh deployment.
DRY_RUN="0"

#!/usr/bin/env bash
# bamboo-rooster — randomized BambooHR clock events.
#
# Usage:
#   rooster <morning|lunch-out|lunch-in|evening>
#   rooster --auth-check
#
# Reads config from $ROOSTER_HOME/.env, the API key from
# $ROOSTER_HOME/secrets/api-key, and writes events to $ROOSTER_LOG_FILE.

set -euo pipefail

# --- Bootstrap paths ------------------------------------------------------
# Resolve $0 through symlinks portably so the same script works whether it
# was invoked directly (./bin/rooster) or via a ~/.local/bin/rooster symlink.
# BSD readlink has no -f and there's no portable realpath in macOS bash 3.2,
# so we walk the chain by hand.
_self="$0"
while [[ -L "$_self" ]]; do
  _target=$(readlink "$_self")
  if [[ "$_target" != /* ]]; then
    _target="$(dirname "$_self")/$_target"
  fi
  _self="$_target"
done
ROOSTER_ROOT="${ROOSTER_ROOT:-$(cd "$(dirname "$_self")/.." && pwd)}"
unset _self _target

# --- Help (runnable without any config) -----------------------------------

print_help() {
  cat <<'EOF'
rooster — randomized BambooHR clock-in/out

Usage:
  rooster <phase>          Run a phase. Gates run, random sleep within the
                           phase window, then clock_in or clock_out.
  rooster config           Print the active configuration (read-only).
  rooster edit ...         Edit a closed clock entry's start/end.
                           Run `rooster edit --help` for the flags.
  rooster --auth-check     Live API round-trip; verifies the key works.
                           Bypasses the cached employee ID.
  rooster -h | --help      This help.

Phases:
  morning    clock in     window 08:30 – 09:30 (Mon–Fri)
  lunch-out  clock out    window 12:45 – 13:15
  lunch-in   clock in     window 13:30 – 14:00
  evening    clock out    window 17:30 – 18:30

Gates (each phase, before AND after the random sleep):
  weekday  →  BambooHR /whos_out (PTO, sick, holiday, …)
           →  idempotency against today's timesheet
           →  random sleep
           →  re-check whos_out + idempotency
           →  clock_in / clock_out

Files:
  ~/.bamboo-rooster/.env             config (subdomain, employee ID, DRY_RUN)
  ~/.bamboo-rooster/secrets/api-key  BambooHR API key (chmod 600)
  ~/.bamboo-rooster/log.jsonl        structured event log
  ~/.bamboo-rooster/state.json       caches (employee ID, whos_out, etc.)
  ~/.bamboo-rooster/skip-today       touch to bow out for today (auto-clears)

Related commands:
  rooster-status                     7-day summary; flags missed phases
  rooster-rotate-key                 interactively replace the API key
  launchctl kickstart gui/$(id -u)/com.bamboo-rooster.<phase>
                                     manually fire a scheduled launchd job

Wiki: https://github.com/dfsotop/bamboo-rooster
EOF
}

case "${1:-}" in
  -h|--help|help)
    print_help
    exit 0
    ;;
esac
ROOSTER_HOME="${ROOSTER_HOME:-${HOME}/.bamboo-rooster}"

if [[ -f "$ROOSTER_HOME/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$ROOSTER_HOME/.env"
  set +a
fi

export ROOSTER_HOME
export ROOSTER_ROOT

# A jq binary downloaded by setup.sh (when Homebrew is absent) lives under
# $ROOSTER_HOME/bin. Make it discoverable via PATH so we don't need to teach
# every jq call about a custom location.
if [[ -d "$ROOSTER_HOME/bin" ]]; then
  PATH="$ROOSTER_HOME/bin:$PATH"
fi

export STATE_FILE="${STATE_FILE:-$ROOSTER_HOME/state.json}"
export ROOSTER_LOG_FILE="${ROOSTER_LOG_FILE:-$ROOSTER_HOME/log.jsonl}"
export SKIP_TODAY_FILE="${SKIP_TODAY_FILE:-$ROOSTER_HOME/skip-today}"
export ROOSTER_API_KEY_FILE="${ROOSTER_API_KEY_FILE:-$ROOSTER_HOME/secrets/api-key}"
# Prefer the user-customized windows.conf (written once by install.sh) over
# the repo default. Both files share the same format.
if [[ -z "${WINDOWS_CONF:-}" ]]; then
  if [[ -f "$ROOSTER_HOME/windows.conf" ]]; then
    WINDOWS_CONF="$ROOSTER_HOME/windows.conf"
  else
    WINDOWS_CONF="$ROOSTER_ROOT/config/windows.conf"
  fi
fi
export WINDOWS_CONF

mkdir -p "$ROOSTER_HOME"

# shellcheck disable=SC1091
source "$ROOSTER_ROOT/lib/log.sh"
# shellcheck disable=SC1091
source "$ROOSTER_ROOT/lib/state.sh"
# shellcheck disable=SC1091
source "$ROOSTER_ROOT/lib/auth.sh"
# shellcheck disable=SC1091
source "$ROOSTER_ROOT/lib/bamboo.sh"
# shellcheck disable=SC1091
source "$ROOSTER_ROOT/lib/gates.sh"

# --- Subcommands ----------------------------------------------------------

if [[ "${1:-}" == "config" ]]; then
  PHASE=config
  shift
  case "${1:-}" in
    -h|--help|help)
      cat <<'EOF'
Usage: rooster config

Print the active rooster configuration — subdomain, employee ID,
timezone, DRY_RUN mode, phase windows, scheduler state, log freshness.
Read-only: no API calls, no files modified. The API key value is
never printed; only its file size and permissions.
EOF
      exit 0
      ;;
  esac

  _bold() { printf '\n\033[1m%s\033[0m\n' "$*"; }

  printf '🐓 bamboo-rooster · config\n'

  _bold "Paths"
  printf '  source dir       %s\n' "$ROOSTER_ROOT"
  printf '  state dir        %s\n' "$ROOSTER_HOME"
  printf '  log file         %s\n' "$ROOSTER_LOG_FILE"

  _bold "BambooHR"
  printf '  subdomain        %s\n' "${BAMBOOHR_SUBDOMAIN:-(not set)}"
  if [[ -n "${BAMBOOHR_EMPLOYEE_ID:-}" ]]; then
    printf '  employee ID      %s (pinned in .env)\n' "$BAMBOOHR_EMPLOYEE_ID"
  else
    cached_id=$(state_get self_employee_id)
    if [[ -n "$cached_id" ]]; then
      printf '  employee ID      %s (cached; auto-resolved from key)\n' "$cached_id"
    else
      printf '  employee ID      (not resolved yet — run rooster --auth-check)\n'
    fi
  fi
  if [[ -f "$ROOSTER_API_KEY_FILE" ]]; then
    key_size=$(wc -c < "$ROOSTER_API_KEY_FILE" | tr -d ' ')
    key_perms=$(ls -l "$ROOSTER_API_KEY_FILE" | awk '{print $1}')
    if [[ "$key_perms" == -rw-------* ]]; then
      printf '  api key file     %s bytes, chmod 600 ✓\n' "$key_size"
    else
      printf '  api key file     %s bytes, WARN perms %s (should be -rw-------)\n' "$key_size" "$key_perms"
    fi
  else
    printf '  api key file     (missing — run rooster-rotate-key)\n'
  fi

  _bold "Schedule"
  if [[ "${DRY_RUN:-0}" == "1" ]]; then
    printf '  mode             DRY_RUN — no real clock_in/out\n'
  else
    printf '  mode             LIVE — real clock_in/out\n'
  fi
  printf '  TZ               %s\n' "${TZ:-(unset, defaults to system TZ)}"

  if [[ -f "$WINDOWS_CONF" ]]; then
    while read -r p start end; do
      [[ "$p" =~ ^# ]] && continue
      [[ -z "$p" ]] && continue
      printf '  %-10s %s – %s  → %s\n' "$p" "$start" "$end" "$(action_for_phase "$p")"
    done < "$WINDOWS_CONF"
    if [[ "$WINDOWS_CONF" == "$ROOSTER_ROOT/config/windows.conf" ]]; then
      printf '  (using repo defaults — rm ~/.bamboo-rooster/windows.conf to re-prompt)\n'
    fi
  else
    printf '  windows          (none — re-run install.sh)\n'
  fi

  _bold "Scheduler"
  case "$(uname -s)" in
    Darwin)
      uid=$(id -u)
      for ph in morning lunch-out lunch-in evening; do
        label="com.bamboo-rooster.${ph}"
        if launchctl list 2>/dev/null | awk -v p="$label" '$3 == p' | grep -q .; then
          printf '  %-10s launchd loaded\n' "$ph"
        else
          printf '  %-10s NOT LOADED — run install.sh\n' "$ph"
        fi
      done
      ;;
    Linux)
      for ph in morning lunch-out lunch-in evening; do
        unit="bamboo-rooster-${ph}.timer"
        if systemctl --user is-enabled "$unit" >/dev/null 2>&1; then
          printf '  %-10s systemd enabled\n' "$ph"
        else
          printf '  %-10s NOT ENABLED — run install.sh\n' "$ph"
        fi
      done
      ;;
    *)
      printf '  (unknown OS: %s)\n' "$(uname -s)"
      ;;
  esac

  _bold "Health"
  if [[ -f "$ROOSTER_LOG_FILE" ]]; then
    log_count=$(wc -l < "$ROOSTER_LOG_FILE" | tr -d ' ')
    printf '  log events       %s\n' "$log_count"
    if [[ "$log_count" -gt 0 ]]; then
      last_event=$(tail -1 "$ROOSTER_LOG_FILE" | jq -r '
        "\(.ts) — \(.phase) \(.event)" +
        (if .reason  then " (\(.reason))" else "" end) +
        (if .http_status then " HTTP \(.http_status)" else "" end)
      ' 2>/dev/null)
      printf '  last event       %s\n' "${last_event:-(unparseable)}"
    fi
  else
    printf '  log events       (none yet)\n'
  fi
  if [[ -f "$SKIP_TODAY_FILE" ]]; then
    if skip_today_active; then
      printf '  skip-today       ACTIVE — every phase will skip today\n'
    else
      printf '  skip-today       file present but stale (next phase will clear it)\n'
    fi
  fi

  exit 0
fi

if [[ "${1:-}" == "edit" ]]; then
  PHASE=edit
  shift
  rooster_edit_help() {
    cat <<'EOF'
Usage:
  rooster edit --id <N> --start HH:MM [--end HH:MM]
  rooster edit --id <N> --start-random HH:MM-HH:MM [--end HH:MM]
  rooster edit --latest --start HH:MM [--end HH:MM]
  rooster edit --latest --start-random HH:MM-HH:MM [--end HH:MM]

Edits a CLOSED clock entry's start (and optionally end). BambooHR's
edit endpoint requires both start and end as local HH:MM strings —
open entries can't be edited directly. Close the entry first (run
the next clock-out phase manually, or rooster lunch-out/evening) and
then edit it.

  --id N                edit this specific entry id
  --latest              edit today's most recent clock entry
  --start HH:MM         set the entry's start to this local time
  --start-random A-B    pick a uniform-random start in [A, B] local
  --end HH:MM           override the entry's end; otherwise the existing
                        end is preserved
EOF
  }

  edit_id=""
  edit_start=""
  edit_start_range=""
  edit_end=""
  use_latest=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) rooster_edit_help; exit 0 ;;
      --id) edit_id="$2"; shift 2 ;;
      --latest) use_latest=1; shift ;;
      --start) edit_start="$2"; shift 2 ;;
      --start-random) edit_start_range="$2"; shift 2 ;;
      --end) edit_end="$2"; shift 2 ;;
      *) echo "rooster edit: unknown arg '$1'" >&2; rooster_edit_help; exit 2 ;;
    esac
  done

  if [[ -z "$edit_id" && "$use_latest" -ne 1 ]]; then
    echo "rooster edit: pass --id <N> or --latest" >&2; exit 2
  fi
  if [[ -z "$edit_start" && -z "$edit_start_range" ]]; then
    echo "rooster edit: pass --start HH:MM or --start-random A-B" >&2; exit 2
  fi
  # Validate user-supplied times. The JSON body is built via jq -n --arg
  # (safe regardless of input), but a malformed time would still produce
  # a 4xx from BambooHR with confusing error text — better to refuse early.
  _hhmm_re='^([01][0-9]|2[0-3]):[0-5][0-9]$'
  if [[ -n "$edit_start" && ! "$edit_start" =~ $_hhmm_re ]]; then
    echo "rooster edit: --start expects HH:MM (24h)" >&2; exit 2
  fi
  if [[ -n "$edit_end" && ! "$edit_end" =~ $_hhmm_re ]]; then
    echo "rooster edit: --end expects HH:MM (24h)" >&2; exit 2
  fi
  if [[ -n "$edit_id" && ! "$edit_id" =~ ^[0-9]+$ ]]; then
    echo "rooster edit: --id expects a numeric entry id" >&2; exit 2
  fi

  if ! employee_id=$(bamboo_resolve_self_employee_id); then
    echo "rooster edit: could not resolve employee id (HTTP $(bamboo_last_status))" >&2
    exit 1
  fi

  today=$(date +%F)

  # Pull today's entries to find the target.
  if ! response=$(bamboo_get_timesheet_today "$employee_id" "$today"); then
    echo "rooster edit: timesheet fetch failed (HTTP $(bamboo_last_status))" >&2
    exit 1
  fi

  if [[ "$use_latest" -eq 1 ]]; then
    edit_id=$(echo "$response" | jq -r \
      'map(select((.type? // "") == "clock")) | sort_by(.start) | last.id // empty')
    if [[ -z "$edit_id" ]]; then
      echo "rooster edit: no clock entries found today to edit" >&2
      exit 1
    fi
  fi

  entry=$(echo "$response" | jq -c --argjson id "$edit_id" '.[] | select(.id == $id)')
  if [[ -z "$entry" || "$entry" == "null" ]]; then
    echo "rooster edit: entry $edit_id not found in today's timesheet" >&2
    exit 1
  fi

  cur_start_iso=$(echo "$entry" | jq -r '.start // empty')
  cur_end_iso=$(echo "$entry" | jq -r '.end // empty')
  entry_date=$(echo "$entry" | jq -r '.date // empty')

  # Resolve the new start.
  if [[ -n "$edit_start_range" ]]; then
    start_lo="${edit_start_range%-*}"
    start_hi="${edit_start_range#*-}"
    if [[ "$start_lo" == "$start_hi" || -z "$start_lo" || -z "$start_hi" ]]; then
      echo "rooster edit: --start-random expects HH:MM-HH:MM" >&2; exit 2
    fi
    lo_s=$(_hhmm_to_seconds "$start_lo")
    hi_s=$(_hhmm_to_seconds "$start_hi")
    range=$(( hi_s - lo_s ))
    if (( range <= 0 )); then
      echo "rooster edit: --start-random range must be positive" >&2; exit 2
    fi
    pick=$(( lo_s + RANDOM % range ))
    edit_start=$(printf "%02d:%02d" $(( pick / 3600 )) $(( pick / 60 % 60 )))
  fi

  # Resolve the end. Open entries (cur_end_iso empty) need an explicit --end.
  if [[ -z "$edit_end" ]]; then
    if [[ -z "$cur_end_iso" ]]; then
      echo "rooster edit: entry $edit_id is open (no end). Pass --end HH:MM" >&2
      echo "  or close it first via clock-out, then re-run." >&2
      exit 1
    fi
    edit_end=$(iso_to_local_hhmm "$cur_end_iso")
  fi

  echo "· editing entry ${edit_id}: start=${edit_start} end=${edit_end} (was start=$(iso_to_local_hhmm "$cur_start_iso") end=$(iso_to_local_hhmm "${cur_end_iso:-—}"))"

  if [[ "${DRY_RUN:-0}" == "1" ]]; then
    log_event dry_run edit entry_id="$edit_id" new_start="$edit_start" new_end="$edit_end"
    echo "· DRY RUN — no API call made"
    exit 0
  fi

  if bamboo_update_clock_entry "$edit_id" "$employee_id" "$entry_date" "$edit_start" "$edit_end"; then
    log_event success edit entry_id="$edit_id" new_start="$edit_start" new_end="$edit_end" http_status="$(bamboo_last_status)"
    echo "✓ entry ${edit_id} now start=${edit_start} end=${edit_end}"
    exit 0
  else
    log_event failed edit entry_id="$edit_id" http_status="$(bamboo_last_status)"
    echo "✗ edit failed (HTTP $(bamboo_last_status))" >&2
    exit 1
  fi
fi

if [[ "${1:-}" == "--auth-check" ]]; then
  PHASE=auth-check
  # Force a real API round-trip; bypass the env override and the cached
  # employee ID. Otherwise a revoked key falsely reports "key works"
  # because resolve_self_employee_id returns the cache without calling out.
  if response=$(bamboo_request GET "/employees/0/?fields=id") \
     && id=$(echo "$response" | jq -r '.id // empty') \
     && [[ -n "$id" ]]; then
    # Warn loudly if a new key resolves to a different employee — could
    # mean an admin gave you a service-account key, or the .env points at
    # someone else. Either way the phases would start clocking the wrong
    # employee silently.
    prev=$(state_get self_employee_id)
    if [[ -n "$prev" && "$prev" != "$id" ]]; then
      echo "⚠  cached employee id was $prev, new key resolves to $id" >&2
      echo "   if unexpected, check $ROOSTER_HOME/.env (BAMBOOHR_EMPLOYEE_ID) and the key itself" >&2
    fi
    state_set self_employee_id "$id"
    echo "✓ key works (employee ID: $id)"
    exit 0
  else
    echo "✗ auth failed (HTTP $(bamboo_last_status)). See $ROOSTER_LOG_FILE." >&2
    exit 1
  fi
fi

if [[ $# -lt 1 ]]; then
  echo "rooster: missing phase. Try 'rooster --help'." >&2
  exit 2
fi

PHASE="$1"
export PHASE

case "$PHASE" in
  morning|lunch-out|lunch-in|evening) : ;;
  *) echo "rooster: unknown phase '$PHASE'. Try 'rooster --help'." >&2; exit 2 ;;
esac

today=$(date +%F)
DRY_RUN="${DRY_RUN:-0}"

# --- Gate 1: manual override ---------------------------------------------

if skip_today_active; then
  log_event skipped "$PHASE" reason=manual-override
  exit 0
fi
if [[ -f "$SKIP_TODAY_FILE" ]]; then
  rm -f "$SKIP_TODAY_FILE"
fi

# --- Gate 2: weekday -----------------------------------------------------

if ! is_weekday "$today"; then
  log_event skipped "$PHASE" reason=weekend
  exit 0
fi

# --- Resolve self employee ID --------------------------------------------

if ! employee_id=$(bamboo_resolve_self_employee_id); then
  log_event failed "$PHASE" reason=resolve-employee-id http_status="$(bamboo_last_status)"
  exit 1
fi

# --- Gate 3: BambooHR time-off + holidays --------------------------------

if reason_detail=$(is_on_time_off_or_holiday "$employee_id" "$today"); then
  # Gate echoes "whos-out-api-error" if it couldn't reach BambooHR and
  # skipped conservatively — surface that as the real reason instead of
  # the misleading default "time-off-or-holiday".
  log_event skipped "$PHASE" reason="${reason_detail:-time-off-or-holiday}"
  exit 0
fi

# --- Gate 4: idempotency -------------------------------------------------

if skip_detail=$(already_clocked_for_phase "$employee_id" "$PHASE" "$today"); then
  # already_clocked_for_phase optionally echoes one "key=value" pair
  # describing what's blocking (e.g. clocked_in_at=09:15). Unquoted so it
  # naturally becomes the kv arg to log_event when non-empty.
  if [[ -n "$skip_detail" ]]; then
    # shellcheck disable=SC2086
    log_event skipped "$PHASE" reason=already-clocked $skip_detail
  else
    log_event skipped "$PHASE" reason=already-clocked
  fi
  exit 0
fi

# --- Random sleep spread before the action -------------------------------
# Pick a uniform-random offset in [0, window_size_seconds) and sleep that
# long. The clock event fires at "now + offset" — no window-bound target,
# no backdating. BambooHR ignores clockInTime in submissions anyway and
# always uses its own "now"; trying to backdate was theatre.
#
# Scheduling is the launchd plist's job, not this script's. Invoking
# manually outside the configured window will clock at the invocation
# moment plus the random spread; that's intended.

if ! window_size=$(window_size_seconds "$PHASE"); then
  log_event failed "$PHASE" reason=missing-window
  exit 1
fi

if (( window_size <= 0 )); then
  offset=0
else
  offset=$(( RANDOM % window_size ))
fi

log_event planned "$PHASE" \
  offset_seconds="$offset" \
  window_size_seconds="$window_size"

if [[ "$DRY_RUN" == "1" ]]; then
  log_event dry_run "$PHASE" \
    would_sleep_seconds="$offset" \
    would_action="$(action_for_phase "$PHASE")"
  exit 0
fi

sleep "$offset"

# Recompute today after the sleep — defensive against late fires crossing
# local midnight (windows max out at 18:30 + 60min so in practice never).
today=$(date +%F)

# --- Re-check gates 3 + 4 after sleeping ----------------------------------

if reason_detail=$(is_on_time_off_or_holiday "$employee_id" "$today" --force-refresh); then
  log_event skipped "$PHASE" reason="${reason_detail:-time-off-or-holiday}-post-sleep"
  exit 0
fi
if skip_detail=$(already_clocked_for_phase "$employee_id" "$PHASE" "$today"); then
  if [[ -n "$skip_detail" ]]; then
    # shellcheck disable=SC2086
    log_event skipped "$PHASE" reason=already-clocked-post-sleep $skip_detail
  else
    log_event skipped "$PHASE" reason=already-clocked-post-sleep
  fi
  exit 0
fi

# --- Fire the action -----------------------------------------------------

case "$(action_for_phase "$PHASE")" in
  clock_in)
    if bamboo_clock_in "$employee_id"; then
      log_event success "$PHASE" action=clock_in http_status="$(bamboo_last_status)"
    else
      log_event failed "$PHASE" action=clock_in http_status="$(bamboo_last_status)"
      exit 1
    fi
    ;;
  clock_out)
    if bamboo_clock_out "$employee_id"; then
      log_event success "$PHASE" action=clock_out http_status="$(bamboo_last_status)"
    else
      log_event failed "$PHASE" action=clock_out http_status="$(bamboo_last_status)"
      exit 1
    fi
    ;;
esac

#!/usr/bin/env bash
# rotate-key — interactively replace the BambooHR API key.
#
# Reads the new key from stdin (no echo), validates it against
# /employees/0/?fields=id, and only writes it on success. The cron jobs
# pick up the new key on their next fire — no container restart needed.

set -euo pipefail

# Resolve $0 through symlinks portably (see bin/rooster for the rationale).
_self="$0"
while [[ -L "$_self" ]]; do
  _target=$(readlink "$_self")
  if [[ "$_target" != /* ]]; then
    _target="$(dirname "$_self")/$_target"
  fi
  _self="$_target"
done
ROOSTER_ROOT="${ROOSTER_ROOT:-$(cd "$(dirname "$_self")/.." && pwd)}"
unset _self _target

case "${1:-}" in
  -h|--help|help)
    cat <<'EOF'
rooster-rotate-key — replace the BambooHR API key

Usage:
  rooster-rotate-key            Prompt for a new key (no echo), validate it
                                against /employees/0/?fields=id, and write
                                ~/.bamboo-rooster/secrets/api-key only on
                                success. The next launchd fire uses the new
                                key — no restart, no reload.
  rooster-rotate-key -h|--help  This help.

Generate a fresh key at:
  https://<your-subdomain>.bamboohr.com/settings/api.php
EOF
    exit 0
    ;;
esac
ROOSTER_HOME="${ROOSTER_HOME:-${HOME}/.bamboo-rooster}"

if [[ -f "$ROOSTER_HOME/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$ROOSTER_HOME/.env"
  set +a
fi

KEY_FILE="${ROOSTER_API_KEY_FILE:-$ROOSTER_HOME/secrets/api-key}"
KEY_DIR=$(dirname "$KEY_FILE")
mkdir -p "$KEY_DIR"
chmod 700 "$KEY_DIR" 2>/dev/null || true

if [[ -z "${BAMBOOHR_SUBDOMAIN:-}" ]]; then
  echo "rotate-key: BAMBOOHR_SUBDOMAIN not set (check $ROOSTER_HOME/.env)" >&2
  exit 1
fi

read -r -s -p "new BambooHR API key: " new_key
echo
if [[ -z "$new_key" ]]; then
  echo "rotate-key: empty input, aborting" >&2
  exit 2
fi

# Validate against /employees/0/?fields=id with the candidate key.
# Credentials go in a chmod-600 config file rather than curl -u argv —
# otherwise any process running as this user can read the key from
# /proc/<pid>/cmdline or `ps auxww` for the duration of the request.
creds_file=$(mktemp "${KEY_DIR}/.creds.XXXXXX")
chmod 600 "$creds_file"
printf 'user = "%s:x"\n' "$new_key" >"$creds_file"

status=$(curl -sS -o /dev/null -w "%{http_code}" \
  --max-time 30 \
  --config "$creds_file" \
  -H "Accept: application/json" \
  "https://api.bamboohr.com/api/gateway.php/${BAMBOOHR_SUBDOMAIN}/v1/employees/0/?fields=id" \
  || echo "000")
rm -f "$creds_file"

if [[ "$status" != 2* ]]; then
  echo "rotate-key: validation failed (HTTP $status). Key NOT saved." >&2
  exit 1
fi

# Atomic write: write to a sibling file then move.
tmp=$(mktemp "${KEY_DIR}/.api-key.XXXXXX")
printf '%s' "$new_key" >"$tmp"
chmod 600 "$tmp"
mv "$tmp" "$KEY_FILE"
echo "✓ key saved to $KEY_FILE (HTTP $status). Next cron run will use it."
